{
  // turns compact folders off in explorer
  "explorer.compactFolders": false,
  // turns the minimap off
  "editor.minimap.enabled": false,
  // set default dark theme
  "workbench.preferredDarkColorTheme": "Default Dark Modern",
  // set prettier as the default formatter for all languages
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  // set the font size
  "editor.fontSize": 16,
  // sets the icon theme to material icon theme
  "workbench.iconTheme": "material-icon-theme",
  // list of words consided spelled correctly
  "cSpell.words": [
    "appspot",
    "gcloudignore",
    "gregwiley",
    "maxlength"
  ]
}
